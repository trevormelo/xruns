sum_multiples_3_or_5 <- function(limit) {
total_sum <- 0
for (i in 1:(limit-1)) {
if (i %% 3 == 0 || i %% 5 == 0) {
total_sum <- total_sum + i
}
}
return(total_sum)
}
limit <- 1000
result <- sum_multiples_3_or_5(limit)
cat("The sum of all multiples of 3 or 5 below", limit, "is:", result, "\n")
sum_multiples_3_or_5 <- function(limit) {
total_sum <- 0
for (i in 1:limit) {
if (i %% 3 == 0 || i %% 5 == 0) {
total_sum <- total_sum + i
}
}
return(total_sum)
}
limit <- 999 # Since we're considering numbers below 1000
result <- sum_multiples_3_or_5(limit)
cat("The sum of all multiples of 3 or 5 below", limit, "is:", result, "\n")
